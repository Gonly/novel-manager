<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>📚 书库 - 小说管理站</title>
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">📚 小说管理站</a>
      <nav>
        <a href="/">书库</a>
        <a href="/book/add">+ 新增</a>
      </nav>
    </div>
  </header>

  <main class="container">

    <!-- Search + filter bar -->
    <div class="filter-row" style="display:flex; gap:10px; padding:20px 0 0; align-items:center;">
      <form class="search-bar" method="GET" action="/" style="padding:0; flex:1; min-width:200px;">
        <input type="text" name="q" placeholder="搜索书名或作者…" value="<%= q %>">
        <button type="submit">🔍 搜索</button>
        <% if (q) { %>
          <a href="/" class="btn btn-secondary" style="padding:10px 16px;">✕ 清除</a>
        <% } %>
      </form>
      <a href="/?fav=1" class="btn <%= locals.showFav ? 'btn-primary' : 'btn-secondary' %>"
         style="padding:10px 16px; font-size:.9rem; white-space:nowrap;">❤️ 只看收藏</a>
      <% if (locals.showFav) { %>
        <a href="/" class="btn btn-secondary" style="padding:10px 16px; font-size:.9rem;">显示全部</a>
      <% } %>
    </div>

    <% if (allTags.length) { %>
    <div class="tag-cloud">
      <% allTags.forEach(function(t) { %>
        <a href="/?tag=<%= encodeURIComponent(t) %>" class="tag-chip <%= tag === t ? 'active' : '' %>"><%= t %></a>
      <% }); %>
      <% if (tag) { %><a href="/" class="tag-chip clear">✕ 清除筛选</a><% } %>
    </div>
    <% } %>

    <% if (books.length) { %>
    <div class="book-grid">
      <% books.forEach(function(book) { %>
      <div class="book-card" data-book-id="<%= book.id %>">
        <a href="/book/<%= book.id %>/read">
          <div class="book-cover <%= book.coverColor %>">
            <span class="cover-char"><%= book.title[0] %></span>
            <button class="fav-btn <%= book.is_favorite ? 'on' : '' %>"
                    data-id="<%= book.id %>" title="收藏"
                    onclick="event.preventDefault(); event.stopPropagation(); toggleFav(this)">❤</button>
          </div>
          <div class="book-info">
            <div class="book-title" title="<%= book.title %>"><%= book.title %></div>
            <div class="book-info-row">
              <span class="book-author"><%= book.author || '佚名' %></span>
              <% if (book.tagList.length) { %>
              <span class="book-tags">
                <% book.tagList.forEach(function(t) { %>
                  <a href="/?tag=<%= encodeURIComponent(t) %>" class="tag-chip"><%= t %></a>
                <% }); %>
              </span>
              <% } %>
              <span class="book-stars" data-rating="<%= book.rating || 0 %>">
                <% for (let i=1; i<=5; i++) { %>
                  <span class="star <%= i <= (book.rating||0) ? 'on' : '' %>">★</span>
                <% } %>
              </span>
              <span class="book-meta">
                <span><%= book.total_pages %> 页</span>
                <span><%= formatSize(book.file_size) %></span>
              </span>
            </div>
          </div>
        </a>
        <div class="book-card-actions">
          <a href="/book/<%= book.id %>/edit">✏️ 编辑</a>
          <form method="POST" action="/book/<%= book.id %>/delete"
                onsubmit="return confirm('确定要删除《<%= book.title %>》吗？');">
            <button type="submit" class="delete-btn">🗑 删除</button>
          </form>
        </div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <span class="big-icon">📖</span>
      <% if (q) { %>
        <p>没有找到匹配「<%= q %>」的书籍</p>
        <p style="margin-top:12px;"><a href="/" class="btn btn-primary">返回书库</a></p>
      <% } else if (locals.showFav) { %>
        <p>还没有收藏的书籍</p>
        <p style="margin-top:12px;"><a href="/" class="btn btn-primary">浏览全部书籍</a></p>
      <% } else { %>
        <p>书库还是空的</p>
        <p style="margin-top:12px;"><a href="/book/add" class="btn btn-primary">+ 新增第一本书</a></p>
      <% } %>
    </div>
    <% } %>

  </main>

  <footer class="site-footer">
    <div class="container"><span>📖 私人小说管理站</span></div>
  </footer>

  <script src="/static/js/main.js"></script>
  <script>
    // Toggle favorite
    async function toggleFav(btn) {
      const id = btn.dataset.id;
      try {
        const resp = await fetch('/api/book/' + id + '/favorite', { method: 'POST' });
        const data = await resp.json();
        btn.classList.toggle('on', data.is_favorite);
      } catch (e) { /* silent */ }
    }
  </script>
</body>
</html>
